  "trace_contract": {
    "enablement": {
      "env": "FJ_SHIM_TRACE",
      "disabled_values": [
        "",
        "0",
        "false",
        "no",
        "off"
      ],
      "body_env": "FJ_SHIM_TRACE_BODY",
      "body_enabled_values": [
        "1",
        "true",
        "yes",
        "on",
        "any other non-empty non-false value for shim gh traces"
      ]
    },
    "gh_record": {
      "required_fields": [
        "timestamp",
        "cwd",
        "argv",
        "route",
        "host",
        "repo",
        "duration_ms",
        "exit_code",
        "stdout",
        "stderr"
      ],
      "optional_fields": [
        "kind"
      ],
      "stdout_stderr_shape": {
        "always": [
          "bytes"
        ],
        "with_body": [
          "excerpt",
          "truncated"
        ]
      },
      "redaction_replacement": "<redacted>",
      "auth_token_stdout_excerpt": "[redacted: gh auth token output]",
      "tests": [
        "tests/test_trace.py::TraceTests",
        "tests/test_routing.py::RoutingTests::test_run_gh_trace_records_forgejo_invocation",
        "tests/test_routing.py::RoutingTests::test_run_gh_trace_suppresses_auth_token_stdout_excerpt"
      ]
    },
    "git_recorder_record": {
      "schema": "gh-forgejo-shim.git-recorder.v1",
      "required_fields": [
        "schema",
        "kind",
        "timestamp",
        "cwd",
        "argv",
        "command_argv",
        "duration",
        "duration_ms",
        "exit_code",
        "stdout_bytes",
        "stderr_bytes",
        "stdout",
        "stderr"
      ],
      "body_excerpt_condition": "FJ_SHIM_TRACE_BODY == \"1\" exactly",
      "body_excerpt_fields": [
        "stdout_excerpt",
        "stderr_excerpt",
        "stdout.excerpt",
        "stderr.excerpt"
      ],
      "redaction_replacement": "[REDACTED]",
      "tests": [
        "tests/test_git_recorder.py::GitRecorderTests"
      ]
    }
  },

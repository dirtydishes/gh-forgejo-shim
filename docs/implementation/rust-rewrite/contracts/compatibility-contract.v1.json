      "repo_context": "any",
      "route": {
        "kind": "delegate",
        "reason": "unsupported command"
      },
      "expected": {
        "exit_code": "real gh exit code",
        "stdout_pattern": "^gh version [0-9]+\\\\.[0-9]+\\\\.[0-9]+",
        "stderr": "real gh stderr"
      },
      "contract": "The shim must not parse or synthesize version output; it forwards the real gh output."

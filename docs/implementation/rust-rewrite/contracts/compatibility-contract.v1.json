      ],
      "status": "supported",
      "route": "management",
      "exit_codes": {
        "all_checks_ok": 0,
        "needs_repairs": 1
      },
      "stdout_shape": [
        "gh-forgejo-shim bootstrap",
        "repo: <host>/<owner>/<repo>|unknown",
        "config: <path>",
        "[ok|fix] <check>: <detail>",
        "repair commands:|setup looks ready"
      ],
      "side_effects": [
        "allowlists detected non-GitHub repo host",
        "never allowlists GitHub hosts",
        "installs managed gh shim",
        "prints but does not run git repair commands"
      ],
      "tests": [
        "tests/test_bootstrap.py::BootstrapTests"
      ]
    },

  "unsupported_behavior": [
    {
      "case": "unsupported top-level managed gh command",
      "behavior": "delegate to real gh",
      "route_reason": "unsupported command"
    },
    {
      "case": "supported family but unsupported subcommand, such as gh pr merge",
      "behavior": "delegate to real gh",
      "route_reason": "unsupported command"
    },
    {
      "case": "supported routed command with unsupported flag",
      "behavior": "return 1 with stderr gh-forgejo-shim: unsupported Forgejo ... flag: <flag>"
    },
    {
      "case": "GitHub repository or GH_HOST=github.com",
      "behavior": "delegate to real gh even if github.com appears in config",
      "route_reason": "host github.com is not allowlisted"
    },
    {
      "case": "allowlisted Forgejo host but no token for routed api/repo/pr/issue calls",
      "behavior": "return 1 with stderr telling the user to run gh-forgejo-shim auth login/import"
    }
  ],

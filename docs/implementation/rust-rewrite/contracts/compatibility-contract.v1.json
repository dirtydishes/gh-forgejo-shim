{
  "schema": "gh-forgejo-shim.compatibility-contract.v1",
  "bead": "gh-forgejo-shim-3sl",
  "parent_epic": "gh-forgejo-shim-d60",
  "phase": "01",
  "phase_title": "freeze compatibility contract",
  "frozen_runtime": {
    "implementation": "python",
    "package_version": "0.1.1",
    "source_layout": "src/gh_forgejo_shim",
    "entrypoints": [
      "gh-forgejo-shim",
      "gfj",
      "managed gh wrapper"
    ]
  },
  "contract_rules": [
    "GitHub and unsupported managed-gh commands delegate to the real gh executable.",
    "Allowlisted non-GitHub Forgejo repositories route only the supported gh auth, api, repo, pr, and issue subsets.",
    "Known GitHub hosts github.com and www.github.com are never treated as Forgejo, even if configured.",
    "Routed JSON output is a GitHub-shaped subset; unsupported requested JSON fields are omitted.",
    "Secrets must not appear in management command output or trace excerpts except that gh auth token intentionally prints the token to stdout.",
    "Trace files are opt-in and must preserve the gh and git-recorder schemas separately."
  ],
  "command_matrix": [
    {
      "id": "management.install_shim",
      "surface": "gh-forgejo-shim|gfj",
      "argv": [
        "install-shim"
      ],
      "status": "supported",
      "route": "management",
      "exit_codes": {
        "success": 0,
        "unmanaged_target_without_force": 1
      },
      "stdout": "installed gh shim at <path>\n",
      "stderr": "gh-forgejo-shim: <error>\n",
      "side_effects": [
        "writes <bin-dir>/gh",
        "creates parent directory",
        "chmods wrapper executable",
        "refuses unmanaged existing gh unless --force"
      ],
      "tests": [
        "tests/test_shim.py::ShimLifecycleTests::test_install_refuses_unrelated_file_without_force",
        "tests/test_shim.py::ShimLifecycleTests::test_install_force_overwrites_and_uninstall_removes"
      ]
    },
    {
      "id": "management.uninstall_shim",
      "surface": "gh-forgejo-shim|gfj",
      "argv": [
        "uninstall-shim"
      ],
      "status": "supported",
      "route": "management",
      "exit_codes": {
        "success": 0,
        "unmanaged_target": 1
      },
      "stdout": "removed gh shim at <path>\n",
      "side_effects": [
        "removes only managed shim files",
        "missing shim is a helper-level no-op"
      ],
      "tests": [
        "tests/test_shim.py::ShimLifecycleTests::test_uninstall_refuses_unrelated_file"
      ]
    },
    {
      "id": "management.doctor",
      "surface": "gh-forgejo-shim|gfj",
      "argv": [
        "doctor"
      ],
      "status": "supported",
      "route": "management",
      "exit_codes": {
        "all_checks_ok": 0,
        "any_warning": 1
      },
      "stdout_shape": [
        "gh-forgejo-shim doctor",
        "[ok|warn] real gh: <detail>",
        "[ok|warn] fj: <detail>",
        "[ok|warn] forgejo hosts: <detail>",
        "[ok|warn] auth token: <detail>",
        "[ok|warn] current repo host: <detail>",
        "[ok|warn] shim path: <detail>",
        "[ok|warn] macOS gui PATH: <detail>"
      ],
      "tests": [
        "tests/test_doctor.py::DoctorTests"
      ]
    },
    {
      "id": "management.bootstrap",
      "surface": "gh-forgejo-shim|gfj",
